# MongoDB connection string (Atlas or local)
MONGODB_URI=mongodb://localhost:27017/placement_portal

# JWT signing secret — MUST be at least 32 characters for HS256
APP_JWT_SECRET=change-me-to-a-long-random-secret-at-least-32-chars

# JWT token lifetime in milliseconds (default 1 hour)
APP_JWT_EXPIRATION_MS=3600000

# Bootstrap an initial admin account on startup
APP_BOOTSTRAP_ADMIN_ENABLED=true
APP_BOOTSTRAP_ADMIN_USERNAME=admin
APP_BOOTSTRAP_ADMIN_PASSWORD=change-me

# Dev only: return the activation token in the initiate-registration response
# so students can self-activate without an email service. Keep false in production.
APP_REGISTRATION_EXPOSE_TOKEN=true

# Comma-separated list of allowed CORS origins (frontend URLs)
APP_CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost:8080,http://localhost:3000
